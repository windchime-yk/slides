{
  "name": "slides",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f",
  "scripts": {
    "create-slide": "deno run --allow-run=pnpm,deno --allow-write --allow-read --allow-env --no-lock scripts/create.ts",
    "dev": "deno run --allow-run=pnpm --allow-read --allow-env --no-lock scripts/dev.ts",
    "build": "rimraf dist && pnpm -r build && tsx index.tsx",
    "preview": "live-server dist/index.html",
    "export": "pnpm -r export",
    "fmt": "deno fmt --ignore=README.md,*/**/*.md"
  },
  "dependencies": {
    "@slidev/cli": "^52.16.0",
    "@slidev/theme-default": "latest",
    "@slidev/theme-seriph": "latest",
    "preact": "^10.22.0",
    "preact-render-to-string": "^6.5.5",
    "vue": "^3.4.22"
  },
  "devDependencies": {
    "@types/node": "^20.14.8",
    "live-server": "^1.2.2",
    "playwright-chromium": "^1.43.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.15.7"
  }
}
